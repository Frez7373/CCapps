local MODEM_SIDE = "top"
rednet.open(MODEM_SIDE)

local DNS_USER = "dns_root_system_v2"
local DNS_PASS = "global_dns_password_123"
local DNS_FILE = "domains.txt"

-- Твой текстовый пароль (теперь можно легко менять прямо здесь)
local DEV_PASSWORD = "admin123" 

-- Состояния браузера
local viewMode = "main" 
local viewTarget = ""
local viewData = nil
local activeLinks = {}
local historyStack = {} 
local bookmarksFile = "bookmarks.txt"

local function getBookmarks()
    if not fs.exists(bookmarksFile) then return {} end
    local file = fs.open(bookmarksFile, "r")
    local data = textutils.unserialize(file.readAll()) or {}
    file.close()
    return data
end

local function saveBookmark(domain)
    local bookmarks = getBookmarks()
    for _, v in ipairs(bookmarks) do
        if v == domain then return false end
    end
    table.insert(bookmarks, domain)
    local file = fs.open(bookmarksFile, "w")
    file.write(textutils.serialize(bookmarks))
    file.close()
    return true
end

local function findServers()
    local ids = { rednet.lookup("cloud_disk") }
    if #ids == 0 or ids[1] == nil then return {} end
    return ids
end

local function sendRequest(user, pass, payload)
    payload.username = user
    payload.password = pass
    local serverIDs = findServers()
    if #serverIDs == 0 then return nil end
    for _, sID in ipairs(serverIDs) do
        rednet.send(sID, payload, "cloud_disk")
        local id, response = rednet.receive("cloud_disk", 1.5)
        if response then return response end
    end
    return nil
end

local function getDNS()
    local serverIDs = findServers()
    if #serverIDs == 0 then return {} end
    for _, sID in ipairs(serverIDs) do
        local payload = {username = DNS_USER, password = DNS_PASS, action = "download", filename = DNS_FILE}
        rednet.send(sID, payload, "cloud_disk")
        local id, response = rednet.receive("cloud_disk", 2.0)
        if response and response.success then
            return textutils.unserialize(response.content) or {}
        end
    end
    sendRequest(DNS_USER, DNS_PASS, {action = "register"})
    return {}
end

local function saveDNS(dnsData)
    local content = textutils.serialize(dnsData)
    return sendRequest(DNS_USER, DNS_PASS, {action = "upload", filename = DNS_FILE, content = content})
end

local function extractLinks(text)
    local links = {}
    for name, domain in text:gmatch("%[([^%-%>]+)%-%>([^%]]+)%]") do
        table.insert(links, { name = name, domain = domain:gsub("%s+", ""):lower() })
    end
    return links
end

local function cleanText(text)
    return text:gsub("%[([^%-%>]+)%-%>[^%]]+%]", "%1")
end

-- Панель разработчика: теперь принимает обычный текстовый пароль
local function devManager()
    term.clear()
    term.setCursorPos(1,1)
    print("=== Developer Menu ===")
    write("Enter developer password: ")
    local inputPass = read("*")
    
    -- Прямое сравнение строк без хэш-функции
    if inputPass ~= DEV_PASSWORD then
        term.setTextColor(colors.red)
        print("\n[!] Access Denied: Incorrect Password.")
        term.setTextColor(colors.white)
        sleep(2) return
    end
    
    while true do
        print("\nDownloading sync data from server...")
        local dns = getDNS()
        term.clear()
        term.setCursorPos(1,1)
        print("=== CloudNet Dev Panel (Manage Sites) ===")
        print("Registered domains:")
        
        local domainsList = {}
        local idx = 1
        for domain, data in pairs(dns) do
            local dType = type(data) == "table" and data.type or "text"
            print(string.format("[%d] cloud://%s (%s)", idx, domain, dType))
            domainsList[idx] = domain
            idx = idx + 1
        end
        
        if idx == 1 then print(" No websites registered yet.") end
        
        print("\n----------------------------------------")
        print("To delete, type the site number.")
        write("Type 'exit' to return: ")
        local choice = read()
        
        if choice:lower() == "exit" then break end
        
        local num = tonumber(choice)
        if num and domainsList[num] then
            local targetDomain = domainsList[num]
            write("Are you sure you want to delete " .. targetDomain .. "? (y/n): ")
            if read():lower() == "y" then
                dns[targetDomain] = nil 
                local res = saveDNS(dns) 
                
                if res and res.success then
                    print("Success: Domain deleted and server updated!")
                else
                    print("Success: File sent to server sync.")
                end
                sleep(1.5)
            end
        else
            print("Invalid selection.")
            sleep(1)
        end
    end
end

local function createSiteManager()
    term.clear()
    term.setCursorPos(1,1)
    print("=== Register a New Website/App ===")
    write("Choose domain (e.g., store): cloud://")
    local domain = read():lower()
    
    if domain == "" or domain:match("%s") then
        print("Error: Domain cannot contain spaces.")
        sleep(2) return
    end
    
    print("Checking availability on network...")
    local dns = getDNS()
    if dns[domain] then
        term.setTextColor(colors.red)
        print("Error: This domain name is already taken!")
        term.setTextColor(colors.white)
        sleep(2) return
    end
    
    print("\nHow would you like to provide the content?")
    print("[1] Type text manually inside the editor")
    print("[2] Import an existing local file / app")
    write("Select option (1-2): ")
    local choice = read()
    local rawContent = ""
    local contentType = "text" 
    
    if choice == "1" then
        print("\nEnter your website content.")
        print("Tip: Add links using [Label->domain]")
        print("To SAVE & PUBLISH, type :w on a new line.")
        print("----------------------------------------")
        local lines = {}
        while true do
            local line = read()
            if line == ":w" then break end
            table.insert(lines, line)
        end
        rawContent = table.concat(lines, "\n")
    elseif choice == "2" then
        print("\nEnter the absolute local file path.")
        write("Path (e.g., /disk/game.lua): ")
        local path = read()
        if not fs.exists(path) or fs.isDir(path) then
            print("Error: File does not exist.")
            sleep(2) return
        end
        print("\nHow should the browser handle this file?")
        print("[1] Text Page (Display source code as text)")
        print("[2] Application (Run it as an executable app)")
        write("Select execution mode (1-2): ")
        local modeChoice = read()
        if modeChoice == "2" then contentType = "app" end
        local file = fs.open(path, "r")
        rawContent = file.readAll()
        file.close()
    else
        print("Invalid option.")
        sleep(2) return
    end
    
    dns[domain] = { type = contentType, content = rawContent }
    saveDNS(dns)
    print("\nSuccessfully published!")
    sleep(2)
end

local function searchEngine(query)
    local dns = getDNS()
    local results = {}
    query = query:lower()
    for domain, data in pairs(dns) do
        local content = type(data) == "table" and data.content or data
        local dType = type(data) == "table" and data.type or "text"
        if domain:find(query) or content:lower():find(query) then
            table.insert(results, { domain = domain, preview = "[" .. dType:upper() .. "] " .. cleanText(content):sub(1, 20) .. "..." })
        end
    end
    return results
end

local function runAsApplication(domain, code)
    term.clear()
    term.setCursorPos(1, 1)
    local tempPath = ".browser_cache_" .. domain .. ".lua"
    local file = fs.open(tempPath, "w")
    file.write(code)
    file.close()
    print("Launching cloud://" .. domain .. "...")
    sleep(0.5)
    local success, err = pcall(shell.run, tempPath)
    if fs.exists(tempPath) then fs.delete(tempPath) end
    if not success then
        term.setBackgroundColor(colors.black)
        term.setTextColor(colors.red)
        print("\n[Application Crashed]\nError: " .. tostring(err))
        print("\nPress any key to return...")
        os.pullEvent("key")
    end
end

local function drawBrowser(mode, target, data, activeLinks)
    term.clear()
    local w, h = term.getSize()
    
    -- Шапка
    term.setBackgroundColor(colors.blue)
    term.setTextColor(colors.white)
    term.setCursorPos(1, 1)
    term.clearLine()
    if mode == "page" then write(" URL: cloud://" .. target)
    elseif mode == "search" then write(" Search Results: " .. target)
    else write(" CloudNet Home Page") end
    
    -- Контент
    term.setBackgroundColor(colors.black)
    term.setCursorPos(1, 3)
    if mode == "main" then
        term.setTextColor(colors.lime)
        print(" Welcome to CloudNet Browser!")
        term.setTextColor(colors.white)
        print("\n Search the network or register domains.")
        
        print("\n Your Bookmarks:")
        local bookmarks = getBookmarks()
        if #bookmarks == 0 then
            term.setTextColor(colors.gray)
            print("  (No bookmarks saved yet. Press [P] on any page)")
        else
            term.setTextColor(colors.yellow)
            for i, b in ipairs(bookmarks) do
                if i > 5 then break end
                print(string.format("  [%d] cloud://%s", i, b))
            end
        end
        
    elseif mode == "page" then
        term.setTextColor(colors.white)
        if data then
            print(cleanText(data))
            if #activeLinks > 0 then
                term.setCursorPos(1, h - 3)
                term.setTextColor(colors.cyan)
                print(string.rep("-", w))
                write(" Links: ")
                term.setTextColor(colors.yellow)
                for i, link in ipairs(activeLinks) do
                    if i > 4 then break end 
                    write("[" .. i .. "] " .. link.name .. "  ")
                end
            end
        else
            term.setTextColor(colors.red)
            print(" Error 404: Website Not Found.")
            term.setTextColor(colors.gray)
            print(" Double-check the URL or use the built-in search engine.")
        end
    elseif mode == "search" then
        term.setTextColor(colors.yellow)
        print(" Search results for '" .. target .. "':")
        print(string.rep("-", w))
        term.setTextColor(colors.white)
        if #data == 0 then
            print(" No results found. Try using different keywords.")
        else
            for i, res in ipairs(data) do
                if i > h - 5 then break end
                term.setTextColor(colors.yellow)
                write("[" .. i .. "] ") 
                term.setTextColor(colors.lime)
                write("cloud://" .. res.domain)
                term.setTextColor(colors.gray)
                print(" " .. res.preview)
            end
        end
    end
    
    -- Панель управления
    term.setBackgroundColor(colors.gray)
    term.setTextColor(colors.yellow)
    term.setCursorPos(1, h)
    term.clearLine()
    local navText = " [S] Search | [G] Go | [C] Create | [D] Dev Panel"
    if #historyStack > 0 then navText = navText .. " | [B] Back" end
    if mode == "page" and data then navText = navText .. " | [P] Bookmark" end
    write(navText)
    term.setBackgroundColor(colors.black)
end

local function loadPage(domain, trackHistory)
    if trackHistory and viewMode == "page" and viewTarget ~= "" then
        table.insert(historyStack, viewTarget)
    end

    local serverIDs = findServers()
    if #serverIDs == 0 then
        viewMode = "page"; viewTarget = domain; viewData = nil; return
    end
    
    local record = nil
    for _, sID in ipairs(serverIDs) do
        local payload = {username = DNS_USER, password = DNS_PASS, action = "download", filename = DNS_FILE}
        rednet.send(sID, payload, "cloud_disk")
        local id, response = rednet.receive("cloud_disk", 2.0)
        if response and response.success then
            local dns = textutils.unserialize(response.content) or {}
            if dns[domain] then record = dns[domain]; break end
        end
    end
    
    activeLinks = {} 
    if record then
        if type(record) == "table" and record.type == "app" then
            runAsApplication(domain, record.content)
            viewMode = "main"
        else
            viewMode = "page"
            viewTarget = domain
            viewData = type(record) == "table" and record.content or record
            activeLinks = extractLinks(viewData)
        end
    else
        viewMode = "page"; viewTarget = domain; viewData = nil 
    end
end

-- Цикл обработки событий
while true do
    drawBrowser(viewMode, viewTarget, viewData, activeLinks)
    local event, p1, p2, p3 = os.pullEvent()
    local w, h = term.getSize()
    
    if event == "key" then
        if p1 == keys.h then
            viewMode = "main"; activeLinks = {}
        elseif p1 == keys.c then
            createSiteManager(); viewMode = "main"; activeLinks = {}
        elseif p1 == keys.d then
            devManager(); viewMode = "main"; activeLinks = {}
        elseif p1 == keys.b and #historyStack > 0 then
            local prev = table.remove(historyStack)
            loadPage(prev, false)
        elseif p1 == keys.p and viewMode == "page" and viewData then
            if saveBookmark(viewTarget) then
                term.setCursorPos(1, h)
                term.setBackgroundColor(colors.lime); term.setTextColor(colors.black); term.clearLine()
                write("Saved to bookmarks!")
            else
                term.setCursorPos(1, h)
                term.setBackgroundColor(colors.red); term.setTextColor(colors.white); term.clearLine()
                write("Already bookmarked!")
            end
            sleep(1)
        elseif p1 == keys.g then
            term.setCursorPos(1, h)
            term.setBackgroundColor(colors.lime); term.setTextColor(colors.black); term.clearLine()
            write("Enter domain: cloud://")
            local domain = read():lower()
            if domain ~= "" then loadPage(domain, true) end
        elseif p1 == keys.s then
            term.setCursorPos(1, h)
            term.setBackgroundColor(colors.yellow); term.setTextColor(colors.black); term.clearLine()
            write("Search Query: ")
            local query = read()
            if query ~= "" then
                viewMode = "search"; viewTarget = query; viewData = searchEngine(query); activeLinks = {}
            end
        end
        
    elseif event == "char" then
        local selection = tonumber(p1)
        if viewMode == "page" and #activeLinks > 0 and selection and activeLinks[selection] then
            loadPage(activeLinks[selection].domain, true)
        elseif viewMode == "search" and type(viewData) == "table" and #viewData > 0 and selection and viewData[selection] then
            loadPage(viewData[selection].domain, true)
        elseif viewMode == "main" and selection then
            local bookmarks = getBookmarks()
            if bookmarks[selection] then loadPage(bookmarks[selection], true) end
        end
        
    elseif event == "mouse_click" and p1 == 1 then
        local mx, my = p2, p3
        
        if my == h then
            if mx >= 2 and mx <= 10 then 
                os.queueEvent("key", keys.s)
            elseif mx >= 13 and mx <= 20 then 
                os.queueEvent("key", keys.g)
            elseif mx >= 23 and mx <= 31 then 
                os.queueEvent("key", keys.c)
            elseif mx >= 34 and mx <= 45 then 
                os.queueEvent("key", keys.d)
            end
        
        elseif viewMode == "page" and my == h - 3 and #activeLinks > 0 then
            if mx >= 9 and mx <= 18 and activeLinks[1] then loadPage(activeLinks[1].domain, true)
            elseif mx >= 21 and mx <= 30 and activeLinks[2] then loadPage(activeLinks[2].domain, true)
            elseif mx >= 33 and mx <= 42 and activeLinks[3] then loadPage(activeLinks[3].domain, true)
            end
            
        elseif my >= 3 and my < h - 2 then
            local lineIndex = my - 2
            if viewMode == "search" and type(viewData) == "table" and viewData[lineIndex] then
                loadPage(viewData[lineIndex].domain, true)
            elseif viewMode == "main" then
                local bookmarks = getBookmarks()
                if bookmarks[lineIndex] then loadPage(bookmarks[lineIndex], true) end
            end
        end
    end
end
